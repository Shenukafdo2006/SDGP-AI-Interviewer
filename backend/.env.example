PORT=5001
FASTAPI_BASE_URL=http://localhost:8000

# Firebase Configuration - Primary Service Account (choose one method)
# Method 1: Environment variables
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY=your_private_key

# Method 2: Service account file path (default)
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json

# Firebase Configuration - Secondary Service Account (optional for alternative features)
FIREBASE_SERVICE_ACCOUNT_PATH_2=serviceAccountKey2.json
